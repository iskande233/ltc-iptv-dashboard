<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121228"
    android:orientation="vertical">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#1E1E38"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:elevation="8dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="← رجوع"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:paddingEnd="16dp"
            android:foreground="@drawable/focus_selector" />

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_admin_logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:text="👁️ إدارة والتحكم في إخفاء الفئات (Groups)"
            android:textColor="#FFD700"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Card 1: إدخال واختيار السيرفر -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_vip_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🌐 رابط السيرفر المراد التحكم بفئاته"
                    android:textColor="#00E5FF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="أدخل رابط Xtream أو M3U، أو اضغط زر الجلب السريع لجلب السيرفر المعمم الحالي."
                    android:textColor="#8891B8"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/inputServerUrl"
                    android:layout_width="match_parent"
                    android:layout_height="66dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_vip_input"
                    android:hint="http://server.com:8080/get.php?username=xxx&amp;password=xxx&amp;type=m3u_plus&amp;output=ts"
                    android:padding="14dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555A7A"
                    android:textSize="12sp"
                    android:maxLines="3" />

                <!-- Buttons Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btnFetchMaster"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_gold_btn"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="⚡ جلب السيرفر المعمم"
                        android:textColor="#000000"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:id="@+id/btnPasteUrl"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_purple_panel"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="📋 لصق الرابط"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginStart="6dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Card 2: أزرار الاستخراج والتصفية -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_vip_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/btnExtractGroups"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_btn_gold"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="🔍 استخراج وجلب جميع الفئات من السيرفر"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Quick toggles (hidden until extracted) -->
                <LinearLayout
                    android:id="@+id/quickTogglesRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <EditText
                        android:id="@+id/inputSearchGroup"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:background="@drawable/bg_vip_input"
                        android:hint="🔍 بحث في أسماء الفئات المستخرجة..."
                        android:paddingHorizontal="14dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#7A82A8"
                        android:textSize="13sp"
                        android:layout_marginBottom="12dp"
                        android:singleLine="true" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/btnShowAll"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1"
                            android:background="#16A34A"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:text="🟢 إظهار كل الفئات"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:id="@+id/btnHideAll"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1"
                            android:background="#DC2626"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:text="🔴 إخفاء كل الفئات"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginStart="6dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Card 3: قائمة الفئات المستخرجة -->
            <LinearLayout
                android:id="@+id/groupsContainerCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_vip_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/groupsSummaryText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📋 الفئات المستخرجة (0 فئة)"
                    android:textColor="#FFD700"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- RecyclerView for Groups -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/groupsRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                <!-- Final Apply Button -->
                <TextView
                    android:id="@+id/btnSaveAndApply"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_btn_gold"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="💾 حفظ وتعميم إعدادات الإخفاء 🚀"
                    android:textColor="#000000"
                    android:textSize="17sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text=""
                android:textColor="#A5B4FC"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
