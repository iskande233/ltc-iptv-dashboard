<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121228"
    android:orientation="vertical">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#1E1E38"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_admin_logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:text="@string/app_name"
            android:textColor="#FFD700"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- 🔒 6-Digit Square Box PIN Code Interface (Centered) -->
        <LinearLayout
            android:id="@+id/screenAuth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_gravity="center"
            android:background="@drawable/bg_card_admin"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="28dp"
            android:layout_margin="24dp">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_admin_logo"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auth_title"
                android:textColor="#FFD700"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/auth_subtitle"
                android:textColor="#B8AFC8"
                android:textSize="14sp" />

            <!-- 6 Square Input Boxes -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:layoutDirection="ltr">

                <EditText
                    android:id="@+id/inputOtp1"
                    android:layout_width="45dp"
                    android:layout_height="52dp"
                    android:layout_marginHorizontal="4dp"
                    android:background="#121228"
                    android:gravity="center"
                    android:inputType="numberPassword"
                    android:maxLength="1"
                    android:nextFocusRight="@+id/inputOtp2"
                    android:textColor="#FFD700"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/inputOtp2"
                    android:layout_width="45dp"
                    android:layout_height="52dp"
                    android:layout_marginHorizontal="4dp"
                    android:background="#121228"
                    android:gravity="center"
                    android:inputType="numberPassword"
                    android:maxLength="1"
                    android:nextFocusLeft="@+id/inputOtp1"
                    android:nextFocusRight="@+id/inputOtp3"
                    android:textColor="#FFD700"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/inputOtp3"
                    android:layout_width="45dp"
                    android:layout_height="52dp"
                    android:layout_marginHorizontal="4dp"
                    android:background="#121228"
                    android:gravity="center"
                    android:inputType="numberPassword"
                    android:maxLength="1"
                    android:nextFocusLeft="@+id/inputOtp2"
                    android:nextFocusRight="@+id/inputOtp4"
                    android:textColor="#FFD700"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/inputOtp4"
                    android:layout_width="45dp"
                    android:layout_height="52dp"
                    android:layout_marginHorizontal="4dp"
                    android:background="#121228"
                    android:gravity="center"
                    android:inputType="numberPassword"
                    android:maxLength="1"
                    android:nextFocusLeft="@+id/inputOtp3"
                    android:nextFocusRight="@+id/inputOtp5"
                    android:textColor="#FFD700"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/inputOtp5"
                    android:layout_width="45dp"
                    android:layout_height="52dp"
                    android:layout_marginHorizontal="4dp"
                    android:background="#121228"
                    android:gravity="center"
                    android:inputType="numberPassword"
                    android:maxLength="1"
                    android:nextFocusLeft="@+id/inputOtp4"
                    android:nextFocusRight="@+id/inputOtp6"
                    android:textColor="#FFD700"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/inputOtp6"
                    android:layout_width="45dp"
                    android:layout_height="52dp"
                    android:layout_marginHorizontal="4dp"
                    android:background="#121228"
                    android:gravity="center"
                    android:inputType="numberPassword"
                    android:maxLength="1"
                    android:nextFocusLeft="@+id/inputOtp5"
                    android:textColor="#FFD700"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnOtpSubmit"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_btn_gold"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/login_royal"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 🛠️ Main Dashboard Container (Hidden until unlocked) -->
        <ScrollView
            android:id="@+id/screenDashboard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Link API Setting - HIDDEN per client (Wizard removed) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_admin"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/api_url_label"
                        android:textColor="#00E5FF"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/inputApiUrl"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="8dp"
                        android:background="#121228"
                        android:paddingHorizontal="12dp"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- Language Switcher -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_admin"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/language_section"
                        android:textColor="#FFD700"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/btnLangAr"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_purple_panel"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:text="@string/arabic"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btnLangEn"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="3dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_purple_panel"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:text="@string/english"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btnLangFr"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_purple_panel"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:text="@string/french"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Gemini AI Admin Assistant -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_admin"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/ai_admin_title"
                        android:textColor="#FFD700"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnGeminiChat"
                        android:layout_width="118dp"
                        android:layout_height="118dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_ai_circle"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="✦
Gemini"
                        android:textColor="#111111"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:text="@string/ai_admin_hint"
                        android:textColor="#B8AFC8"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Master URL + Users Management -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_admin"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/master_server_title"
                        android:textColor="#00E5FF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/master_server_desc"
                        android:textColor="#B8AFC8"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/inputMasterUrl"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="12dp"
                        android:background="#121228"
                        android:hint="http://server/get.php?username=...&amp;password=...&amp;type=m3u_plus&amp;output=ts"
                        android:padding="12dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#888888"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/inputMasterExpiry"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="10dp"
                        android:background="#121228"
                        android:hint="@string/link_expiry_hint"
                        android:padding="12dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#888888"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/btnMasterUrlSubmit"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_btn_gold"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="@string/apply_master_server"
                        android:textColor="#000000"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnOpenServers"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="10dp"
                        android:background="#3d3d5c"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="@string/manage_users_servers"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnIncrementServerRevision"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_purple_panel"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="🔄 فرض تحديث السيرفر على جميع المستخدمين (Server Revision)"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnXtreamTester"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_btn_gold"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="🔍 فاحص الأكواد الذكي — Xtream &amp; M3U Tester"
                        android:textColor="#000000"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Card 1: Generate Automatic Subscription Code -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_admin"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/generate_code_title"
                        android:textColor="#FFD700"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/inputNewCode"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:background="#121228"
                            android:gravity="center"
                            android:hint="@string/code_auto_hint"
                            android:inputType="number"
                            android:maxLength="6"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#888888"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btnGenRandom"
                            android:layout_width="wrap_content"
                            android:layout_height="52dp"
                            android:layout_marginStart="10dp"
                            android:background="#3d3d5c"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:paddingHorizontal="16dp"
                            android:text="@string/random"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/inputUserName"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="12dp"
                        android:background="#121228"
                        android:hint="@string/user_name_hint"
                        android:paddingHorizontal="16dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#888888"
                        android:textSize="15sp" />

                    <EditText
                        android:id="@+id/inputUserPlaylist"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="12dp"
                        android:background="#121228"
                        android:hint="@string/playlist_hint"
                        android:paddingHorizontal="16dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#888888"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/inputLinkExpiry"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="12dp"
                        android:background="#121228"
                        android:hint="@string/link_expiry_hint"
                        android:paddingHorizontal="16dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#888888"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/duration_expiry"
                        android:textColor="#C7B7D8"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView android:id="@+id/btnTrial" android:layout_width="0dp" android:layout_height="44dp" android:layout_marginEnd="4dp" android:layout_weight="1" android:background="#3d3d5c" android:gravity="center" android:text="@string/hours_24" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:id="@+id/btn1Month" android:layout_width="0dp" android:layout_height="44dp" android:layout_marginHorizontal="2dp" android:layout_weight="1" android:background="#3d3d5c" android:gravity="center" android:text="@string/month_1" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:id="@+id/btn3Months" android:layout_width="0dp" android:layout_height="44dp" android:layout_marginHorizontal="2dp" android:layout_weight="1" android:background="#3d3d5c" android:gravity="center" android:text="@string/months_3" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:id="@+id/btn1Year" android:layout_width="0dp" android:layout_height="44dp" android:layout_marginStart="4dp" android:layout_weight="1" android:background="#3d3d5c" android:gravity="center" android:text="@string/year_1" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btnAddCodeSubmit"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/bg_btn_gold"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="@string/generate_submit"
                        android:textColor="#000000"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Card 2: AI M3U Arab Sanitizer & Master Switcher -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_admin"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sanitizer_title"
                        android:textColor="#00E5FF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/sanitizer_desc"
                        android:textColor="#888888"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/inputRawSanitizeUrl"
                        android:layout_width="match_parent"
                        android:layout_height="66dp"
                        android:layout_marginTop="14dp"
                        android:background="#121228"
                        android:hint="@string/raw_m3u_hint"
                        android:padding="12dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#888888"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/btnSanitizeSubmit"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_btn_gold"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="@string/sanitize_submit"
                        android:textColor="#000000"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Output Log -->
                <TextView
                    android:id="@+id/txtAdminLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#121228"
                    android:padding="20dp"
                    android:text="@string/admin_log_placeholder"
                    android:textColor="#4ADE80"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </ScrollView>

        <FrameLayout
            android:id="@+id/adminVoiceOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#CC000000"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">

                <FrameLayout
                    android:id="@+id/adminVoiceGlowContainer"
                    android:layout_width="260dp"
                    android:layout_height="96dp"
                    android:background="@drawable/bg_voice_glow">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/adminVoiceMicIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎙️"
                            android:textSize="38sp" />

                        <TextView
                            android:id="@+id/adminVoiceStatusText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:text="@string/voice_gemini_listening"
                            android:textColor="#00E5FF"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </FrameLayout>

                <TextView
                    android:id="@+id/adminVoiceHintText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center"
                    android:text="@string/voice_overlay_hint"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_purple_panel"
                    android:gravity="center"
                    android:paddingHorizontal="22dp"
                    android:text="@string/voice_cancel_hint"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>
</LinearLayout>
