<?xml version="1.0" encoding="utf-8"?>
<!-- 📱 الصفحة الثالثة: تفاصيل المستخدم مع التحكم الكامل -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121228"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#1E1E38"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="#3d3d5c"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="→"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/user_details_control_title"
            android:textColor="#FFD700"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Detail Info Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_admin"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/registered_data"
                    android:textColor="#FFD700"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView android:id="@+id/lblInfoName" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="👤 الاسم: " android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="8dp" />
                <TextView android:id="@+id/lblInfoCode" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🔑 الكود: " android:textColor="#00E5FF" android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="8dp" />
                <TextView android:id="@+id/lblInfoMaxDev" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="📱 عدد الأجهزة المسموحة: " android:textColor="#FFFFFF" android:textSize="14sp" android:layout_marginBottom="8dp" />
                <TextView android:id="@+id/lblInfoRegDev" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="📱 الأجهزة المسجلة: " android:textColor="#B8AFC8" android:textSize="12sp" android:layout_marginBottom="8dp" />
                <TextView android:id="@+id/lblInfoExpiry" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="📅 تاريخ انتهاء الصلاحية: " android:textColor="#FFFFFF" android:textSize="14sp" android:layout_marginBottom="8dp" />
                <TextView android:id="@+id/lblInfoPlaylist" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🔗 رابط الـ Playlist: " android:textColor="#B8AFC8" android:textSize="11sp" android:layout_marginBottom="12dp" />
                <TextView android:id="@+id/lblInfoLinkExpiry" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="⏳ نهاية الرابط: " android:textColor="#FFD700" android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/cloud_status"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/badgeStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#16A34A"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="✅ Active"
                        android:textColor="#000000"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Tools Control Container -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/google_sheets_tools"
                android:textColor="#00E5FF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Toggle Button -->
            <TextView
                android:id="@+id/btnToggleStatus"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_btn_gold"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/toggle_status"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Edit Button -->
            <TextView
                android:id="@+id/btnEditData"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="#3d3d5c"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/edit_user"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Renew Card Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_admin"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/renew_subscription"
                    android:textColor="#FFD700"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView android:id="@+id/btnRenew24h" android:layout_width="0dp" android:layout_height="40dp" android:layout_marginEnd="4dp" android:layout_weight="1" android:background="#3d3d5c" android:gravity="center" android:text="@string/hours_24" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" />
                    <TextView android:id="@+id/btnRenew1m" android:layout_width="0dp" android:layout_height="40dp" android:layout_marginHorizontal="2dp" android:layout_weight="1" android:background="#3d3d5c" android:gravity="center" android:text="@string/month_1" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" />
                    <TextView android:id="@+id/btnRenew3m" android:layout_width="0dp" android:layout_height="40dp" android:layout_marginHorizontal="2dp" android:layout_weight="1" android:background="#3d3d5c" android:gravity="center" android:text="@string/months_3" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" />
                    <TextView android:id="@+id/btnRenew1y" android:layout_width="0dp" android:layout_height="40dp" android:layout_marginStart="4dp" android:layout_weight="1" android:background="#3d3d5c" android:gravity="center" android:text="@string/year_1" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btnRenewSubmit"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_btn_gold"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/apply_renewal"
                    android:textColor="#000000"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Delete Button -->
            <TextView
                android:id="@+id/btnDeleteAccount"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="#991111"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/delete_user_forever"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
